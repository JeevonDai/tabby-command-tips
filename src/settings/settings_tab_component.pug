h3 {{ t('Command tips') }}

.form-group
  .form-check
    input.form-check-input(type='checkbox', [(ngModel)]='config.enabled', (change)='save()')
    label.form-check-label {{ t('Enable history suggestions') }}

.form-group
  label {{ t('Trigger settings') }}
  .row
    .col-4
      label {{ t('Minimum characters') }}
      input.form-control(type='number', [(ngModel)]='config.minChars', (change)='save()', min='1', max='10')
    .col-4
      label {{ t('Debounce (ms)') }}
      input.form-control(type='number', [(ngModel)]='config.debounceMs', (change)='save()', min='50', max='2000')
    .col-4
      label {{ t('Maximum results') }}
      input.form-control(type='number', [(ngModel)]='config.maxResults', (change)='save()', min='1', max='100')

.form-group
  label {{ t('Matching mode') }}
  select.form-control([(ngModel)]='config.matching', (change)='save()')
    option(value='prefix-fuzzy') {{ t('Prefix first, fuzzy fallback') }}
    option(value='prefix-only') {{ t('Prefix only') }}
    option(value='fuzzy-only') {{ t('Fuzzy only') }}

.form-group
  label {{ t('Scoring weights') }}
  .row
    .col-6
      label {{ t('Recency weight') }}: {{ config.scoring.recencyWeight.toFixed(2) }}
      input.form-control-range(type='range', [(ngModel)]='config.scoring.recencyWeight', (change)='save()', min='0', max='1', step='0.05')
    .col-6
      label {{ t('Frequency weight') }}: {{ config.scoring.frequencyWeight.toFixed(2) }}
      input.form-control-range(type='range', [(ngModel)]='config.scoring.frequencyWeight', (change)='save()', min='0', max='1', step='0.05')

.form-group
  label {{ t('Half-life (days)') }}
  input.form-control(type='number', [(ngModel)]='config.scoring.halfLifeDays', (change)='save()', min='1', max='365', style='width: 120px')

.form-group
  .form-check
    input.form-check-input(type='checkbox', [(ngModel)]='config.showSourceTag', (change)='save()')
    label.form-check-label {{ t('Show source tags (shell / tabby)') }}

.form-group
  .form-check
    input.form-check-input(type='checkbox', [(ngModel)]='config.tabCompletesFirst', (change)='save()')
    label.form-check-label {{ t('Tab completes first suggestion') }}

.form-group
  label {{ t('Confirm selection shortcuts') }}
  .form-check
    input.form-check-input(type='checkbox', [(ngModel)]='config.acceptKeys.enter', (change)='save()')
    label.form-check-label {{ t('Enter confirms') }}
  .form-check
    input.form-check-input(type='checkbox', [(ngModel)]='config.acceptKeys.arrowRight', (change)='save()')
    label.form-check-label {{ t('Right arrow (→) confirms') }}

hr

h4 {{ t('LLM settings') }}

.form-group
  .form-check
    input.form-check-input(type='checkbox', [(ngModel)]='config.llm.enabled', (change)='save()')
    label.form-check-label {{ t('Enable LLM suggestions') }}

.form-group
  label {{ t('LLM provider') }}
  select.form-control([(ngModel)]='config.llm.provider', (change)='onProviderChanged()')
    option(value='openai') OpenAI
    option(value='deepseek') DeepSeek
    option(value='anthropic') Anthropic
    option(value='local') {{ t('Local model') }}

.form-group
  label {{ t('API endpoint') }}
  input.form-control(type='text', [(ngModel)]='config.llm.endpoint', (change)='save()', placeholder='https://api.openai.com/v1/chat/completions')

.form-group
  label {{ t('API key') }}
  input.form-control(type='password', [(ngModel)]='config.llm.apiKey', (change)='save()', placeholder='sk-...')

.form-group
  label {{ t('Model name') }}
  input.form-control(type='text', [(ngModel)]='config.llm.model', (change)='save()', placeholder='gpt-3.5-turbo')

.form-group
  label {{ t('Maximum LLM results') }}
  input.form-control(type='number', [(ngModel)]='config.llm.maxResults', (change)='save()', min='1', max='20')

.form-group
  label {{ t('Request timeout (ms)') }}
  input.form-control(type='number', [(ngModel)]='config.llm.timeoutMs', (change)='save()', min='500', max='30000')

.form-group
  label {{ t('Suggestion modes') }}
  .form-check
    input.form-check-input(type='checkbox', [(ngModel)]='config.llm.modes', (change)='save()', value='completion')
    label.form-check-label {{ t('Command completion') }}
  .form-check
    input.form-check-input(type='checkbox', [(ngModel)]='config.llm.modes', (change)='save()', value='suggestion')
    label.form-check-label {{ t('Command suggestion') }}

hr

h4 {{ t('Command profiles') }}

p.text-muted.mb-2 {{ t('Match window titles (tab title, falling back to profile name) against profiles in order. The first match uses that profile\'s command history; otherwise the Default group is used. Active profile: {name}', { name: activeProfileName }) }}

p.text-muted.mb-2 {{ t('Prompt regex: one pattern per line; capture group 1 is the command text, used to sync input from the terminal line (Tab completion, etc.). Embedded Shell example: `^(?:Shell >|core[\\d+]->)\\s+(.*)$`; numeric prefix device example: `^\\d+>\\s+(.*)$`') }}

.form-group
  table.table.table-sm.profile-table(*ngIf='config.profiles.length > 0')
    thead
      tr
        th {{ t('Name') }}
        th {{ t('Window match regex') }}
        th.prompt-col {{ t('Prompt regex') }}
        th.count-col {{ t('Commands') }}
        th.action-col {{ t('Actions') }}
    tbody
      tr(*ngFor='let profile of config.profiles')
        td
          input.form-control.form-control-sm(
            type='text',
            [(ngModel)]='profile.name',
            (change)='onProfileMetaChanged()',
            [placeholder]='t("Profile name")'
          )
        td
          input.form-control.form-control-sm(
            type='text',
            [(ngModel)]='profile.pattern',
            (change)='onProfileMetaChanged()',
            [disabled]='isDefaultProfile(profile)',
            [placeholder]='isDefaultProfile(profile) ? t("Default group (fallback)") : t("e.g. DU|RU|BMU")'
          )
        td.prompt-col
          textarea.form-control.form-control-sm(
            rows='2',
            [(ngModel)]='profile.promptPatterns',
            (change)='onProfileMetaChanged()',
            placeholder='^(?:Shell >|core[\\d+]->)\\s+(.*)$'
          )
          button.btn.btn-link.btn-sm.p-0.mt-1(
            type='button',
            (click)='applyShellPromptPreset(profile)'
          ) {{ t('Fill Bash/PowerShell preset') }}
          button.btn.btn-link.btn-sm.p-0.mt-1(
            type='button',
            (click)='applyEmbeddedPromptPreset(profile)'
          ) {{ t('Fill embedded Shell preset') }}
        td.count-col {{ historyCountOf(profile.id) }}
        td.action-col
          button.btn.btn-sm.btn-outline-danger(
            type='button',
            [disabled]='isDefaultProfile(profile)',
            (click)='removeProfile(profile)'
          ) {{ t('Delete') }}
  button.btn.btn-sm.btn-outline-primary(type='button', (click)='addProfile()') {{ t('Add profile') }}

hr

.form-group
  label {{ t('Select profile to edit commands') }}
  select.form-control([(ngModel)]='selectedProfileId', style='width: 240px')
    option(*ngFor='let profile of config.profiles', [value]='profile.id') {{ getProfileDisplayName(profile) }}
  p.text-muted.mt-2.mb-2 {{ t('History count: {count}', { count: profileHistoryCount }) }}
  button.btn.btn-danger((click)='clearHistory()') {{ t('Clear profile history') }}

.form-group
  .d-flex.justify-content-between.align-items-center
    label.mb-0 {{ t('Profile commands (editable, drag to sort)') }}
    button.btn.btn-sm.btn-outline-primary(type='button', (click)='addProfileCommand()') {{ t('Add command') }}
  table.table.table-sm.table-striped.command-table(*ngIf='currentProfileEntries.length > 0')
    thead
      tr
        th.drag-col {{ t('Sort') }}
        th {{ t('Command') }}
        th.count-col {{ t('Count') }}
        th.action-col {{ t('Actions') }}
    tbody
      tr(
        *ngFor='let entry of currentProfileEntries; let i = index',
        draggable='true',
        (dragstart)='onRowDragStart(i)',
        (dragover)='onRowDragOver($event)',
        (drop)='onRowDrop(i)',
        (dragend)='onRowDragEnd()',
        [class.dragging]='draggingRowIndex === i'
      )
        td.drag-col.drag-handle([title]='t("Drag to sort")') ≡
        td
          input.form-control.form-control-sm(
            type='text',
            [(ngModel)]='entry.command',
            (change)='onProfileCommandEdited()',
            [placeholder]='t("Enter a command, e.g. git status")'
          )
        td.count-col
          input.form-control.form-control-sm(
            type='number',
            [(ngModel)]='entry.count',
            (change)='onProfileCommandEdited()',
            min='1'
          )
        td.action-col
          button.btn.btn-sm.btn-outline-danger(type='button', (click)='removeProfileCommand(i)') {{ t('Delete') }}
  p.text-muted.mb-0(*ngIf='currentProfileEntries.length === 0') {{ t('No commands in this profile yet. Click "Add command" to get started.') }}
